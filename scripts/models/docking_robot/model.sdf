<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="docking_robot">

    <!-- Root link at ground level. Wheels will lift body naturally. -->
    <link name="base_link">
      <pose>0 0 0.065 0 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.0042</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.0042</iyy><iyz>0</iyz>
          <izz>0.0075</izz>
        </inertia>
      </inertial>

      <!-- Chassis body -->
      <collision name="base_collision">
        <geometry>
          <cylinder><radius>0.15</radius><length>0.10</length></cylinder>
        </geometry>
      </collision>
      <visual name="base_visual">
        <geometry>
          <cylinder><radius>0.15</radius><length>0.10</length></cylinder>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.8 1</ambient>
          <diffuse>0.2 0.2 0.8 1</diffuse>
        </material>
      </visual>

      <!-- Caster: zero-friction sphere fused to chassis -->
      <collision name="caster_collision">
        <pose>-0.10 0 -0.048 0 0 0</pose>
        <geometry>
          <sphere><radius>0.017</radius></sphere>
        </geometry>
        <surface>
          <friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction>
        </surface>
      </collision>
      <visual name="caster_visual">
        <pose>-0.10 0 -0.048 0 0 0</pose>
        <geometry><sphere><radius>0.017</radius></sphere></geometry>
        <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.5 0.5 0.5 1</diffuse></material>
      </visual>

      <!-- Camera box visual -->
      <visual name="camera_visual">
        <pose>0.15 0 0.08 0 0 0</pose>
        <geometry><box><size>0.03 0.08 0.03</size></box></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>

      <!-- Camera sensor embedded in base_link -->
      <sensor name="camera" type="camera">
        <pose>0.15 0 0.08 0 0 0</pose>
        <camera>
          <horizontal_fov>1.3962634</horizontal_fov>
          <image><width>640</width><height>480</height><format>R8G8B8</format></image>
          <clip><near>0.02</near><far>300</far></clip>
        </camera>
        <always_on>1</always_on>
        <update_rate>30</update_rate>
        <visualize>false</visualize>
        <topic>camera/image_raw</topic>
      </sensor>
    </link>

    <!-- ==== LEFT WHEEL ==== -->
    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel</child>
      <pose relative_to="base_link">0 0.16 -0.033 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-inf</lower><upper>inf</upper></limit>
        <dynamics><damping>0.001</damping></dynamics>
      </axis>
    </joint>
    <link name="left_wheel">
      <pose relative_to="left_wheel_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.15</mass>
        <inertia>
          <ixx>0.000082</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.000082</iyy><iyz>0</iyz>
          <izz>0.000082</izz>
        </inertia>
      </inertial>
      <collision name="left_wheel_collision">
        <pose>0 0 0 1.5707963 0 0</pose>
        <geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry>
        <surface><friction><ode><mu>1.5</mu><mu2>1.5</mu2></ode></friction></surface>
      </collision>
      <visual name="left_wheel_visual">
        <pose>0 0 0 1.5707963 0 0</pose>
        <geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry>
        <material><ambient>0.15 0.15 0.15 1</ambient><diffuse>0.15 0.15 0.15 1</diffuse></material>
      </visual>
    </link>

    <!-- ==== RIGHT WHEEL ==== -->
    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel</child>
      <pose relative_to="base_link">0 -0.16 -0.033 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-inf</lower><upper>inf</upper></limit>
        <dynamics><damping>0.001</damping></dynamics>
      </axis>
    </joint>
    <link name="right_wheel">
      <pose relative_to="right_wheel_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.15</mass>
        <inertia>
          <ixx>0.000082</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.000082</iyy><iyz>0</iyz>
          <izz>0.000082</izz>
        </inertia>
      </inertial>
      <collision name="right_wheel_collision">
        <pose>0 0 0 1.5707963 0 0</pose>
        <geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry>
        <surface><friction><ode><mu>1.5</mu><mu2>1.5</mu2></ode></friction></surface>
      </collision>
      <visual name="right_wheel_visual">
        <pose>0 0 0 1.5707963 0 0</pose>
        <geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry>
        <material><ambient>0.15 0.15 0.15 1</ambient><diffuse>0.15 0.15 0.15 1</diffuse></material>
      </visual>
    </link>

    <!-- ==== DIFF DRIVE PLUGIN ====
         Using RELATIVE topic name "cmd_vel" — Gazebo scopes this to
         /model/docking_robot/cmd_vel on the internal transport.
         The bridge maps /model/docking_robot/cmd_vel <-> ROS /cmd_vel.
    -->
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.32</wheel_separation>
      <wheel_radius>0.033</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>

  </model>
</sdf>
